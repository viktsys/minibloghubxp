# Environment Configuration for Mini Blog Hub XP
# Copy this file to .env and modify the values as needed

# =============================================================================
# DEVELOPMENT ENVIRONMENT (default)
# =============================================================================
DEBUG=true
SECRET_KEY=your-development-secret-key-change-in-production
DATABASE_URL=sqlite:///./blog.db
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
UNSPLASH_SECRET_KEY=your-unsplash-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# =============================================================================
# PRODUCTION ENVIRONMENT WITH POSTGRESQL
# =============================================================================
# Uncomment and configure the following for production:

# DEBUG=false
# SECRET_KEY=your-very-secure-secret-key-for-production

# PostgreSQL Database Configuration
# POSTGRES_USER=your_postgres_user
# POSTGRES_PASSWORD=your_secure_postgres_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=minibloghub_prod

# Alternative: You can also use a complete DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/minibloghub_prod

# =============================================================================
# DOCKER COMPOSE ENVIRONMENT
# =============================================================================
# For use with docker-compose:
# DEBUG=false
# DATABASE_URL=postgresql://postgres:postgres@db:5432/minibloghub
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_DB=minibloghub

# =============================================================================
# CLOUD DEPLOYMENT (Heroku, Railway, etc.)
# =============================================================================
# Most cloud providers will automatically set DATABASE_URL
# Just ensure you set:
# DEBUG=false
# SECRET_KEY=your-production-secret-key
